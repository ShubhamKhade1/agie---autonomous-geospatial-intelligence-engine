# Database & Broker
POSTGRES_USER=agie
POSTGRES_PASSWORD=secret
POSTGRES_DB=geospatial_engine
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://agie:secret@db:5432/geospatial_engine

# NASA Earthdata
EARTHDATA_USERNAME=your_username
EARTHDATA_PASSWORD=your_password

# Copernicus Marine Service (CMEMS)
COPERNICUS_USERNAME=your_username
COPERNICUS_PASSWORD=your_password

# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key

# Region of Interest (ROI) default
DEFAULT_ROI_BBOX=-10,20,10,50
DEFAULT_TEMPORAL_START=2024-01-01
DEFAULT_TEMPORAL_END=2024-03-28
